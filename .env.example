# Inserisci qui le tue chiavi API personali. 
# Questo file serve come modello: rinominalo in .env e compila i campi prima di avviare l'applicazione.
# NON caricare mai il file .env reale su GitHub!

# API Token di Apify (necessario per lo scraper di LinkedIn)
APIFY_API_TOKEN=tuo_apify_api_token_qui

# API Key di Google Gemini (necessario per la valutazione AI dei job post)
GEMINI_API_KEY=tua_gemini_api_key_qui

# API Key di Tavily (necessario solo se utilizzi lo script startup_outreach.py per lo scouting di startup)
TAVILY_API_KEY=tua_tavily_api_key_qui

# Configurazione per l'invio delle notifiche Email tramite SMTP (es. Gmail)
EMAIL_SENDER=tua_email_mittente@gmail.com
EMAIL_PASSWORD=tua_app_password_senza_spazi
EMAIL_RECIPIENT=tua_email_destinatario@gmail.com

# Credenziali in formato JSON dell'Account di Servizio Firebase Admin SDK (necessario per Firestore)
# Deve essere formattato come stringa JSON su una singola riga. Esempio: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "tuo_progetto_id"}
